{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "ask": {
      "description": "Reviews every action before executing. Use @ask when you want to approve edits, commands, and tasks interactively.",
      "mode": "primary",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "bash": { "git *": "allow", "*": "ask" },
        "task": "ask",
        "webfetch": "ask",
        "websearch": "ask"
      }
    }
  }
}
